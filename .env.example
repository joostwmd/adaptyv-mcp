# In-memory mock API (shared mockdata + createMockFoundryClient). Values: 1, true, yes.
# `pnpm run inspector` in packages/mcp sets this. Omit or set 0/false for real API.
FOUNDRY_USE_MOCK=

# Required when FOUNDRY_USE_MOCK is off.
FOUNDRY_API_TOKEN=
FOUNDRY_API_BASE_URL=https://foundry-api-public.adaptyvbio.com/api/v1
MODE=stdio
PORT=3333
# HTTP mode: bind locally by default (MCP transport security)
HOST=127.0.0.1
# Comma-separated allowed Origin values for Streamable HTTP (DNS rebinding). Empty = allow any Origin.
ALLOWED_ORIGINS=
